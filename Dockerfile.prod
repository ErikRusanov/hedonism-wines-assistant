# syntax=docker/dockerfile:1
#
# Production serving image. Self-contained for query-time serving of the
# transferred index:
#
#   * the index was built with OpenRouter's text-embedding-3-small (1536-dim),
#     so the query side embeds via OpenRouter too (EMBEDDING_PROVIDER=openrouter,
#     routed through the proxy). No local torch/sentence-transformers needed —
#     the image stays lean (~300 MB instead of ~2 GB).
#   * bakes in data/sparse_encoder.json, required by the hybrid retriever
#     (SPARSE_ENABLED=true) — without it retrieval silently degrades to dense.
#   * the 376 bottle JPGs under src/.../static/bottles/ come in via `COPY src`
#     (not excluded by .dockerignore), so /bottles/<SKU>.jpg works.
#
# Shipped to the server via `docker save | docker load` (no registry pull).
# See scripts/deploy.sh.
FROM python:3.12-slim AS base

ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1

# uv for fast, reproducible installs.
COPY --from=ghcr.io/astral-sh/uv:latest /uv /usr/local/bin/uv

WORKDIR /app

# Dependencies first for better layer caching. Base deps only — embeddings are
# remote (OpenRouter), so the heavy [embed] extra is intentionally omitted.
COPY pyproject.toml README.md ./
COPY src ./src
RUN uv pip install --system --no-cache .

# Sparse encoder consumed by the query side (data/sparse_encoder.json default).
# Reachable in the build context thanks to the `!data/sparse_encoder.json`
# negation in .dockerignore.
COPY data/sparse_encoder.json /app/data/sparse_encoder.json

EXPOSE 8000

CMD ["uvicorn", "hedonism_assistant.api.app:app", "--host", "0.0.0.0", "--port", "8000"]
