# --- OpenRouter (OpenAI-compatible API) ---
OPENROUTER_API_KEY=sk-or-your-key-here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Model slugs (verify exact slugs against OpenRouter /models).
# Generation: grounded answer synthesis with citations.
GENERATION_MODEL=anthropic/claude-opus-4-8
# Cheap/fast model: query parsing, listwise reranking, LLM-as-judge.
UTILITY_MODEL=anthropic/claude-haiku-4-5

# Optional fallback models, comma-separated, tried in order on failure.
GENERATION_FALLBACK_MODELS=
UTILITY_FALLBACK_MODELS=

# --- Embeddings (local by default; runs offline) ---
# Dense vectors come from a local sentence-transformers model, so indexing and
# retrieval work without OpenRouter. Install the stack with: uv pip install -e ".[embed]".
# Set EMBEDDING_PROVIDER=openrouter (and an OpenRouter embedding slug) to switch back.
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=BAAI/bge-base-en-v1.5
# Must match the model: bge-base=768, bge-m3=1024. Frozen index<->query contract.
EMBEDDING_DIMENSIONS=768
# "" auto-detects the device (mps/cuda/cpu).
EMBEDDING_DEVICE=
# BGE wants this instruction on the query side only (passages get none).
EMBEDDING_QUERY_PROMPT=Represent this sentence for searching relevant passages:
EMBEDDING_BATCH_SIZE=64

# --- Qdrant ---
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=hedonism_wines

# --- Indexing ---
# Qdrant collection geometry. The vector names and sparse toggle are the frozen
# I-3/I-5 contract: the query side must read the same names and load the same
# persisted sparse encoder, or retrieval skews.
QDRANT_DENSE_VECTOR_NAME=dense
QDRANT_SPARSE_VECTOR_NAME=sparse
SPARSE_ENABLED=true
SPARSE_ENCODER_PATH=data/sparse_encoder.json
INDEX_BATCH_SIZE=128

# --- App ---
LOG_LEVEL=INFO
LOG_JSON=true
REQUEST_TIMEOUT_SECONDS=60
MAX_RETRIES=3

# Query understanding (self-query): turn the toggle off to skip LLM parsing and
# fall back to pure semantic search; temperature 0 keeps extraction deterministic.
QUERY_PARSING_ENABLED=true
QUERY_PARSE_TEMPERATURE=0.0

# --- Data extraction (data track, offline) ---
# The catalogue is no longer scraped. Product-page HTML is captured by hand (see
# data/chrome_capture_prompt.md) and dropped as <slug>.html files in the dir
# below; `extract` parses + normalizes them into canonical Wine cards. The base
# URL only synthesizes a page URL from a slug for the parser.
CATALOGUE_BASE_URL=https://hedonism.co.uk
HTML_INPUT_DIR=data/cache/html
EXTRACT_OUTPUT_PATH=data/wines.enriched.jsonl
# Characters of the tasting note folded into the embedding passport.
EMBEDDING_TEXT_NOTES_CHARS=600
