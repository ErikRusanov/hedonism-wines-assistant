# Production env for the Docker stack (docker-compose.prod.yml).
# scripts/deploy.sh copies this to .env.prod, prompts for OPENROUTER_API_KEY and
# generates AUTH_PASSWORD. .env.prod is gitignored — never commit real secrets.

# --- OpenRouter (OpenAI-compatible API) ---
OPENROUTER_API_KEY=sk-or-your-key-here
# Point at the gated FastAPI proxy on the VPN host (it forwards to OpenRouter).
# Direct: https://openrouter.ai/api/v1
OPENROUTER_BASE_URL=https://216.57.111.116:8443/v1
# Sent as `X-Proxy-Token` on every request so the proxy lets it through. Leave
# empty when OPENROUTER_BASE_URL points straight at openrouter.ai.
PROXY_AUTH_TOKEN=
GENERATION_MODEL=anthropic/claude-opus-4-8
UTILITY_MODEL=anthropic/claude-haiku-4-5
GENERATION_FALLBACK_MODELS=
UTILITY_FALLBACK_MODELS=

# --- Embeddings ---
# MUST match what built the transferred index (frozen index<->query contract).
# The prod image bakes the BAAI/bge-base-en-v1.5 weights; do not change these.
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=BAAI/bge-base-en-v1.5
EMBEDDING_DIMENSIONS=768
EMBEDDING_DEVICE=
EMBEDDING_QUERY_PROMPT=Represent this sentence for searching relevant passages:
EMBEDDING_BATCH_SIZE=64

# --- Qdrant ---
# Reached over the compose network; overridden by compose too. No host port.
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=hedonism_wines

# --- Indexing / sparse (query side reads the baked sparse encoder) ---
QDRANT_DENSE_VECTOR_NAME=dense
QDRANT_SPARSE_VECTOR_NAME=sparse
SPARSE_ENABLED=true
SPARSE_ENCODER_PATH=data/sparse_encoder.json
INDEX_BATCH_SIZE=128

# --- App ---
LOG_LEVEL=INFO
LOG_JSON=true
REQUEST_TIMEOUT_SECONDS=60
MAX_RETRIES=3

# --- Access control (enabled in production) ---
# deploy.sh fills AUTH_PASSWORD with a generated secret and prints it once.
# Browser logs in at /login (cookie); API callers send
#   Authorization: Bearer <AUTH_PASSWORD>   (or X-Auth-Password). /health is public.
AUTH_PASSWORD=
AUTH_COOKIE_NAME=hw_auth

# --- Serving ---
# Locked to the production origin (not "*").
CORS_ALLOW_ORIGINS=https://hedonism-wines.era-lands.ru

# --- Retrieval / generation tuning (prod defaults = repo defaults) ---
QUERY_PARSING_ENABLED=true
QUERY_PARSE_TEMPERATURE=0.0
RETRIEVE_TOP_N=40
RERANK_TOP_K=8
RERANK_ENABLED=true
RERANKER_KIND=llm
RERANK_TEMPERATURE=0.0
MMR_ENABLED=false
MMR_LAMBDA=0.5
RETRIEVE_RELAX_FILTERS_ON_EMPTY=true
GENERATION_TEMPERATURE=0.3
GENERATION_MAX_TOKENS=2048
GENERATION_CONTEXT_MAX_WINES=8
GENERATION_NOTE_CHARS=400
GENERATION_MAX_SUGGESTIONS=3
